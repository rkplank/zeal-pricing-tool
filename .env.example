# Zeal Pricing Tool - environment configuration
# Copy to .env and fill in real values. .env is gitignored.

# eBay API mode. "synthetic" uses the in-process fake; "live" hits the real Marketplace Insights API.
# Stay on "synthetic" until eBay developer-program access is approved.
ZEAL_EBAY_MODE=synthetic

# eBay API credentials. Required when ZEAL_EBAY_MODE=live; ignored otherwise.
# Obtain from your eBay developer-program account once Marketplace Insights access is granted.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# eBay API environment. "production" or "sandbox".
EBAY_ENVIRONMENT=production

# Optional: override the default SQLite path.
# ZEAL_DB_PATH=data/zeal.db
